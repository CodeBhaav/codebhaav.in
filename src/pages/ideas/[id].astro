---
import BaseLayout from "@/layouts/BaseLayout.astro";
import IdeaDetailIsland from "@/components/react/islands/IdeaDetailIsland";

export const prerender = false;

const { id } = Astro.params;
if (!id) {
	return Astro.redirect("/ideas");
}

const ogImage = `/api/og/idea.png?id=${encodeURIComponent(id)}`;
---

<BaseLayout title="Idea" ogImage={ogImage}>
	<section class="mx-auto max-w-3xl px-4 sm:px-6 py-16 md:py-20">
		<IdeaDetailIsland client:only="react" ideaId={id} />
	</section>
</BaseLayout>
