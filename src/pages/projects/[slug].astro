---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectDetailIsland from "@/components/react/islands/ProjectDetailIsland";

export const prerender = false;

const { slug } = Astro.params;
if (!slug) {
	return Astro.redirect("/projects");
}

const ogImage = `/api/og/project.png?slug=${encodeURIComponent(slug)}`;
---

<BaseLayout title="Project" ogImage={ogImage}>
	<section class="mx-auto max-w-6xl px-4 sm:px-6 py-16 md:py-20">
		<ProjectDetailIsland client:only="react" slug={slug} />
	</section>
</BaseLayout>
