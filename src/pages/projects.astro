---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/static/PageHeader.astro";

const tracks = [
  {
    eyebrow: "Track 1",
    title: "Sprint weekends",
    description:
      "Three-day, three-track sprints. Frontend, backend, design. Pair up, ship something small, demo to the cohort. The point is shipping, not collecting badges.",
  },
  {
    eyebrow: "Track 2",
    title: "Open-source pair work",
    description:
      "Adopt a real open-source issue together. One member writes, another reviews. We'll seed the issue queue from the founding cohort's projects.",
  },
  {
    eyebrow: "Track 3",
    title: "Build-in-public threads",
    description:
      "Members shipping a side project document the build week-by-week. Other members read, comment, and steal good ideas.",
  },
];
---

<BaseLayout
  title="Projects"
  description="What we'll build together once the community opens."
  ogImage="/api/og.png?page=projects"
>
  <PageHeader
    eyebrow="Projects"
    title="Nothing's shipped yet."
    titleAccent="Here's what's coming."
    description="We're pre-launch. Once the platform opens, members will pair on real projects across three tracks. No tutorials, no toy demos, no make-believe portfolios."
    meta="Tracks open with the founding cohort. More to follow."
  />

  <section class="px-4 sm:px-6 py-20 md:py-24 border-b border-border">
    <div class="w-full">
      <div
        class="grid grid-cols-1 gap-px bg-border md:grid-cols-3 rounded-card overflow-hidden border border-border"
      >
        {
          tracks.map((t, i) => (
            <div
              class="reveal bg-card p-7 h-full"
              style={`--reveal-delay: ${i * 100}ms`}
            >
              <p class="font-mono text-[11px] uppercase tracking-wider text-accent">
                {t.eyebrow}
              </p>
              <h3 class="mt-3 text-lg font-semibold tracking-tight text-text-primary">
                {t.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-text-secondary">
                {t.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-4 sm:px-6 py-20 md:py-24">
    <div class="max-w-3xl">
      <p
        class="reveal font-mono text-[11px] uppercase tracking-wider text-text-muted"
      >
        Have an idea?
      </p>
      <h2
        class="reveal mt-4 text-2xl md:text-3xl font-semibold tracking-tighter text-balance"
        style="--reveal-delay: 100ms"
      >
        Pitch a project for the founding cohort.
      </h2>
      <p
        class="reveal mt-6 text-base text-text-secondary leading-relaxed"
        style="--reveal-delay: 200ms"
      >
        If you've got a project you'd want to build with two other devs, tell us
        about it. The strongest pitches become the first sprint weekends once
        the platform opens.
      </p>
      <a
        href="/contact"
        class="reveal mt-8 inline-flex h-11 items-center justify-center rounded-button border border-border bg-transparent px-6 text-sm font-medium text-text-primary hover:bg-surface hover:border-border-hover transition-colors"
        style="--reveal-delay: 300ms"
      >
        Send us your idea
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="ml-2"
          ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
        >
      </a>
    </div>
  </section>
</BaseLayout>
