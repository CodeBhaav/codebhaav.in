---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/static/PageHeader.astro";

const channels = [
  {
    title: "Email",
    hint: "Best way to reach us",
    value: "pranav@codebhaav.in",
    href: "mailto:pranav@codebhaav.in",
    icon: '<rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />',
  },
  {
    title: "Location",
    hint: "Where we're based",
    value: "Amravati, Maharashtra, India",
    href: null,
    icon: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" />',
  },
  {
    title: "GitHub",
    hint: "Open-source work",
    value: "github.com/CodeBhaav",
    href: "https://github.com/CodeBhaav",
    icon: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" /><path d="M9 18c-4.51 2-5-2-7-2" />',
  },
  {
    title: "Instagram",
    hint: "Follow our journey",
    value: "instagram.com/codebhaav",
    href: "https://instagram.com/codebhaav",
    icon: '<rect width="20" height="20" x="2" y="2" rx="5" ry="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />',
  },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch with the CodeBhaav team."
  ogImage="/api/og.png?page=contact"
>
  <PageHeader
    eyebrow="Contact"
    title="Say hello,"
    titleAccent="or send an idea."
    description="Email is the fastest way. We read everything. Project pitches, founding-member questions, partnership ideas  all welcome."
  />

  <section class="px-6 py-20 md:py-24">
    <div
      class="w-full grid grid-cols-1 gap-px bg-border md:grid-cols-2 rounded-card overflow-hidden border border-border"
    >
      {
        channels.map((c, i) => (
          <div
            class="reveal bg-card p-7 transition-colors hover:bg-surface"
            style={`--reveal-delay: ${i * 80}ms`}
          >
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-button border border-border bg-background text-text-secondary">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={c.icon}
              />
            </div>
            <h2 class="text-base font-semibold tracking-tight text-text-primary">
              {c.title}
            </h2>
            <p class="mt-1 font-mono text-[11px] uppercase tracking-wider text-text-muted">
              {c.hint}
            </p>
            {c.href ? (
              <a
                href={c.href}
                target={c.href.startsWith("http") ? "_blank" : undefined}
                rel={c.href.startsWith("http") ? "noopener" : undefined}
                class="mt-3 inline-block text-sm text-accent hover:underline"
              >
                {c.value}
              </a>
            ) : (
              <p class="mt-3 text-sm text-text-secondary">{c.value}</p>
            )}
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
