---
import "@/styles/global.css";
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import AdminSidebarIsland from "@/components/react/islands/AdminSidebarIsland";

// Auth gate lives in src/middleware.ts so non-admin requests never reach
// this layout. By the time we render here the user is verified admin.

interface Props {
	title: string;
	active:
		| "overview"
		| "waitlist"
		| "founding-members"
		| "ideas"
		| "projects";
}

const { title, active } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta name="robots" content="noindex,nofollow" />
		<title>{title} · CodeBhaav Admin</title>
	</head>
	<body class="bg-background text-text-primary antialiased">
		<div class="flex min-h-screen">
			<AdminSidebarIsland
				client:load
				active={active}
				variant="desktop"
			/>
			<div class="flex-1 min-w-0 flex flex-col">
				<AdminSidebarIsland
					client:load
					active={active}
					variant="mobile"
				/>
				<main class="flex-1 px-4 py-6 sm:px-6 lg:px-10 lg:py-10">
					<slot />
				</main>
			</div>
		</div>
	</body>
</html>
