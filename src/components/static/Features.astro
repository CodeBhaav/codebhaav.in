---
import { siteConfig } from "@/lib/site-config";

const featureIcons: Record<string, string> = {
  build:
    '<path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/>',
  community:
    '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  open: '<circle cx="12" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><path d="M18 9v2c0 .6-.4 1-1 1H7c-.6 0-1-.4-1-1V9"/><path d="M12 12v3"/>',
};
---

<section class="px-6 py-24 md:py-32">
  <div class="mx-auto w-full">
    <p
      class="reveal font-mono text-[11px] uppercase tracking-wider text-text-muted"
    >
      What we're building
    </p>

    <h2
      class="reveal mt-4 text-3xl md:text-4xl font-semibold tracking-tighter text-balance max-w-2xl"
      style="--reveal-delay: 100ms"
    >
      Three things, done well.
    </h2>

    <div
      class="mt-12 grid grid-cols-1 gap-px bg-border md:grid-cols-3 rounded-card overflow-hidden border border-border"
    >
      {
        siteConfig.features.map((feature, i) => (
          <div
            class="reveal bg-card p-7 h-full transition-colors hover:bg-surface group"
            style={`--reveal-delay: ${150 + i * 80}ms`}
          >
            <svg
              class="mb-5 text-accent"
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={featureIcons[feature.id]}
            />
            <h3 class="text-base font-semibold tracking-tight text-text-primary">
              {feature.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
