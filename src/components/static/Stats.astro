---
import { siteConfig } from "@/lib/site-config";
---

<section class="border-y border-border">
	<div class="mx-auto grid grid-cols-2 md:grid-cols-4 divide-x divide-y md:divide-y-0 divide-border">
		{siteConfig.stats.map((stat, i) => (
			<div class="reveal px-6 py-10 md:py-12" style={`--reveal-delay: ${i * 80}ms`}>
				<p class="text-2xl md:text-3xl font-semibold tracking-tight text-text-primary">
					{stat.value}
				</p>
				<p class="mt-2 font-mono text-[11px] uppercase tracking-wider text-text-muted">
					{stat.label}
				</p>
			</div>
		))}
	</div>
</section>
